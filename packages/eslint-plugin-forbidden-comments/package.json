{
	"name": "eslint-plugin-forbidden-comments",
	"version": "0.0.1",
	"description": "ESLint plugin to disallow comment blocks — prevents comments from leaking into production code and prevents LLMs from over commenting code.",
	"type": "module",
	"license": "MIT",
	"repository": {
		"url": "https://github.com/humanshield-sidepack/scorm-packager",
		"type": "git"
	},
	"author": {
		"name": "Rachid Boudjelida",
		"email": "rachidboudjelida@gmail.com"
	},
	"homepage": "https://github.com/humanshield-sidepack/scorm-packager/tree/master/packages/eslint-plugin-forbidden-comments",
	"keywords": [
		"eslint",
		"eslint-plugin",
		"comments",
		"lint",
		"svelte"
	],
	"engines": {
		"node": ">=18"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"files": [
		"dist",
		"README.MD",
		"LICENSE"
	],
	"scripts": {
		"build": "tsc",
		"check-types": "tsc --noEmit",
		"lint": "eslint src",
		"prepublishOnly": "pnpm build && pnpm pack"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@repo/typescript-config": "workspace:*",
		"eslint": "^9.39.1",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.50.0"
	},
	"peerDependencies": {
		"eslint": "^9.0.0"
	}
}
